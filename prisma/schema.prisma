// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
  // The 'url' line has been removed from here
}

/////// Company /////////////////////////////////

model Company {
  id      Int    @id @default(autoincrement())
  name    String
  address String?

  @@map("Companies")
}

/////// Destination /////////////////////////////

model Destination {
  id   Int    @id @default(autoincrement())
  name String

  @@map("Destinations")
}

////// Trucks //////////////////////////////////

model Truck {
  id   Int    @id @default(autoincrement())
  truckNumber String

  @@map("Trucks")
}

/////// Employee //////////////////////////////

model Employee {
  id              Int     @id @default(autoincrement())
  employeeName    String
  employeePhoneNo String?

  @@map("Employees")
}

//////// Trip ///////////////////////////////////

model Trip {
  id            Int      @id @default(autoincrement())
  companyId     Int
  destinationId Int
  employeeId    Int
  truckId       Int

  tripType      String
  driverAmount  Float?

  tripDate      DateTime
  tripAmount    Float

  isOmani       String
  omaniName     String?
  omaniAmount   Float?

  image         String?

  @@map("Trips")
}

//////// Expense ///////////////////////////////////

model Expense {
  id          Int      @id @default(autoincrement())

  employeeId  Int
  truckId     Int

  expenseDate DateTime

  category    String
  details     String?

  amount      Float

  image       String?

  createdAt   DateTime @default(now())

  @@map("Expenses")
}

////////////// Invoice Counter ///////////////////////////////////////////////////////

model InvoiceCounter {
  id          Int      @id @default(autoincrement())
  year        Int      @unique
  last_number Int      @default(0)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("invoice_counters")
}

///////////////// Billing //////////////////////////////////////////////////////////////

enum PaymentStatus {
  PAID
  UNPAID
}

model Billing {
  id            Int           @id @default(autoincrement())
  invoiceNo     String        @unique
  companyId     Int
  date          DateTime      @default(now())
  billImage     String?
  grandTotal    Float

  paymentStatus PaymentStatus @default(UNPAID) 

  items         BillingItem[]

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("Billings")
}

model BillingItem {
  id            Int     @id @default(autoincrement())
  billingId     Int
  tripId        Int

  description   String
  vehicleNo     String

  quantity      Float
  rent          Float

  taxableAmount Float
  vat           Float
  totalAmount   Float

  billing       Billing @relation(fields: [billingId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([billingId])
  @@index([tripId])    
  @@map("BillingItems")
}

///////////////// Purpose //////////////////////////////////////////////////////////////

model Purpose {
  id        Int       @id @default(autoincrement())
  name      String

  accounts  Account[]

  @@map("purposes")
}

model Account {
  id          Int       @id @default(autoincrement())
  purposeId   Int
  description String?
  type        AccountType
  amount      Float
  date        DateTime

  purpose     Purpose   @relation(fields: [purposeId], references: [id])

  @@map("accounts")
}

enum AccountType {
  INCOME
  EXPENSE
}

model Suggestion {
  id   Int    @id @default(autoincrement())
  name String

  @@map("suggestions")
}

////////////////// WorkshopBill //////////////////////////////////////////////////

model WorkshopBill {
  id             Int      @id @default(autoincrement())
  bill_no        String
  vehicle_no     String
  name           String?
  date           DateTime
  payment_status String
  total_amount   Float

  items          WorkshopItem[]

  @@map("WorkshopBills")
}

model WorkshopItem {
  id          Int    @id @default(autoincrement())
  description String
  price       Float
  billId      Int

  bill        WorkshopBill @relation(fields: [billId], references: [id])

  @@map("WorkshopItems")
}

////////////// Employee Account/////////////////////////////////////////////////////////////

model EmployeeAccount {
  id          Int      @id @default(autoincrement())

  employeeId  Int

  month       Int      // 1 = Jan, 2 = Feb, 3 = Mar

  date        DateTime
  type        EntryType
  amount      Decimal  @db.Decimal(10,2)

  remarks     String?

  @@map("employee_accounts")
}

enum EntryType {
  CREDIT
  DEBIT
}


////////////// SparePart /////////////////////////////////////////////////////////////////////////

model sparepart_category {
  id          Int      @id @default(autoincrement())
  name        String
  description String?

  spareparts  sparepart[]
}

model sparepart_supplier {
  id        Int     @id @default(autoincrement())
  name      String
  phone     String?
  address   String?

  stocks    sparepart_stock[]
}

model sparepart {
  id           Int      @id @default(autoincrement())
  name         String
  part_number  String   @unique
  category_id  Int?

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  category     sparepart_category? @relation(fields: [category_id], references: [id])
  stocks       sparepart_stock[]
}

model sparepart_stock {
  id             Int      @id @default(autoincrement())
  sparepart_id   Int
  supplier_id    Int?
  type           String   // IN / OUT
  quantity       Int
  note           String?
  created_at     DateTime @default(now())

  sparepart      sparepart @relation(fields: [sparepart_id], references: [id])
  supplier       sparepart_supplier? @relation(fields: [supplier_id], references: [id])
}

////////////////////////////////////////////////////////////////////////////////////

model DashboardUser {
  id        Int      @id @default(autoincrement())
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("DashboardUsers")
}



